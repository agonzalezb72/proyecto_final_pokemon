<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.image.*?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.text.Font?>

<VBox prefHeight="600.0" prefWidth="800.0" spacing="20.0" style="-fx-background-color: #2f3640;" xmlns="http://javafx.com/javafx/8" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.pokemon.controles.ControladorCombate">
    <padding>
        <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
    </padding>

    <HBox alignment="TOP_RIGHT" spacing="20.0">
        <VBox alignment="CENTER_RIGHT" spacing="5.0">
            <Label fx:id="lblNombreRival" text="RIVAL" textFill="WHITE">
                <font><Font name="System Bold" size="20.0" /></font>
            </Label>
            <ProgressBar fx:id="pbHpRival" prefWidth="200.0" progress="1.0" style="-fx-accent: #2ecc71;" />
            <Label fx:id="lblHpRival" text="100 / 100 HP" textFill="#bdc3c7" />
        </VBox>
        <ImageView fx:id="imgRival" fitHeight="150.0" fitWidth="150.0" pickOnBounds="true" preserveRatio="true" />
    </HBox>

    <HBox alignment="CENTER_LEFT" spacing="20.0">
        <ImageView fx:id="imgJugador" fitHeight="180.0" fitWidth="180.0" pickOnBounds="true" preserveRatio="true" />
        <VBox alignment="CENTER_LEFT" spacing="5.0">
            <Label fx:id="lblNombreJugador" text="TU POKÉMON" textFill="WHITE">
                <font><Font name="System Bold" size="24.0" /></font>
            </Label>
            <ProgressBar fx:id="pbHpJugador" prefWidth="250.0" progress="1.0" style="-fx-accent: #2ecc71;" />
            <Label fx:id="lblHpJugador" text="100 / 100 HP" textFill="#bdc3c7" />
        </VBox>
    </HBox>

    <HBox spacing="20.0" VBox.vgrow="ALWAYS">
        <GridPane fx:id="gridHabilidades" hgap="10.0" vgap="10.0" prefWidth="350.0">
            <columnConstraints>
                <ColumnConstraints hgrow="SOMETIMES" minWidth="10.0" prefWidth="100.0" />
                <ColumnConstraints hgrow="SOMETIMES" minWidth="10.0" prefWidth="100.0" />
            </columnConstraints>
            <rowConstraints>
                <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES" />
                <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES" />
                <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES" />
            </rowConstraints>
            
            </GridPane>

        <TextArea fx:id="txtLog" editable="false" prefHeight="150.0" prefWidth="400.0" style="-fx-control-inner-background: #34495e; -fx-text-fill: #f1c40f;" wrapText="true">
            <font>
                <Font name="Monospaced Regular" size="13.0" />
            </font>
        </TextArea>
    </HBox>
    <Button fx:id="btnVolver" text="Volver al Menú" visible="false" onAction="#handleVolverMenu" />
</VBox>