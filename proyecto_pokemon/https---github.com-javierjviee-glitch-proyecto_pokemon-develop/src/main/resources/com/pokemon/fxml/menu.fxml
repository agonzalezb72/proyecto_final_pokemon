<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>
<?import javafx.geometry.Insets?>

<VBox alignment="TOP_CENTER" prefHeight="600.0" prefWidth="800.0" spacing="30.0" 
      style="-fx-background-color: #1e272e;" 
      xmlns="http://javafx.com/javafx/8" xmlns:fx="http://javafx.com/fxml/1" 
      fx:controller="com.pokemon.controles.ControladorMenu">
    <children>
        <Label text="ELIJE TU COMPAÑERO" textFill="WHITE">
            <font>
                <Font name="System Bold" size="36.0" />
            </font>
            <VBox.margin>
                <Insets top="40.0" />
            </VBox.margin>
        </Label>
        
        <ScrollPane fitToWidth="true" style="-fx-background: transparent; -fx-background-color: transparent;">
            <content>
                <FlowPane fx:id="containerPokemon" alignment="CENTER" hgap="25.0" vgap="25.0" prefWrapLength="750.0">
                    <padding>
                        <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
                    </padding>
                </FlowPane>
            </content>
        </ScrollPane>
    </children>
</VBox>