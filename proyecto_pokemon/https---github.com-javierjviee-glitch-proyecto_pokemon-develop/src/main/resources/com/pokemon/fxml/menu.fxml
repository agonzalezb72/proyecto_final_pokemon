<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.image.*?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.text.Font?>

<!-- Cambié la ruta del controlador para que coincida con tu estructura plana -->
<VBox alignment="CENTER" spacing="30.0" style="-fx-background-color: #f0f0f0;" 
      xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" 
      fx:controller="controlador.ControlMenu">
    <padding>
        <Insets bottom="40.0" left="40.0" right="40.0" top="40.0" />
    </padding>

    <Label text="SIMULADOR DE COMBATE POKÉMON" textFill="#2c3e50">
        <font>
            <Font name="System Bold" size="28.0" />
        </font>
    </Label>

    <VBox alignment="CENTER" spacing="15.0" style="-fx-background-color: white; -fx-border-color: #bdc3c7; -fx-border-radius: 10; -fx-background-radius: 10;">
        <padding>
            <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
        </padding>
        
        <Label text="Selecciona tu criatura para la batalla:" textFill="#7f8c8d">
            <font>
                <Font size="16.0" />
            </font>
        </Label>

        <!-- Este ComboBox debe ser poblado dinámicamente por el DataLoader (Gson) -->
        <ComboBox fx:id="comboPokemon" onAction="#mostrarVistaPrevia" prefWidth="250.0" promptText="-- Elige un Pokémon --" style="-fx-font-size: 14px;" />

        <!-- Asegúrate de que las rutas en el JSON empiecen por /img/ para que esto funcione -->
        <ImageView fx:id="imgPrevia" fitHeight="200.0" fitWidth="200.0" pickOnBounds="true" preserveRatio="true">
            <VBox.margin>
                <Insets top="10.0" />
            </VBox.margin>
        </ImageView>
    </VBox>

    <Button fx:id="btnIniciar" mnemonicParsing="false" onAction="#iniciarCombate" prefHeight="50.0" prefWidth="200.0" 
            style="-fx-background-color: #e74c3c; -fx-text-fill: white; -fx-font-weight: bold; -fx-cursor: hand;" text="¡LUCHAR!">
        <font>
            <Font size="18.0" />
        </font>
    </Button>
</VBox>
